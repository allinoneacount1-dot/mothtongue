---
const nav = [
  { label: 'World', href: '/world' },
  { label: 'Bestiary', href: '/bestiary' },
  { label: 'Play', href: '/play' },
  { label: 'Chronicle', href: '/chronicle' },
  { label: 'Summon', href: '/summon' },
];

const currentPath = Astro.url.pathname;
---
<script>
  const btn = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-close');
  const links = menu?.querySelectorAll('a');
  const open = () => { menu?.classList.remove('hidden'); menu?.classList.add('flex'); };
  const closeMenu = () => { menu?.classList.add('hidden'); menu?.classList.remove('flex'); };
  btn?.addEventListener('click', open);
  close?.addEventListener('click', closeMenu);
  links?.forEach((l) => l.addEventListener('click', closeMenu));
</script>

<nav class="fixed top-0 left-0 right-0 z-50 bg-moss/80 backdrop-blur-md border-b border-bone/5">
  <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
    <a href="/" class="focus-moth">
      <svg viewBox="0 0 120 40" class="w-24 h-8 text-bone" aria-label="MOTHTONGUE" role="img">
        <path d="M60 8 C55 8, 42 14, 38 22 C34 30, 40 36, 52 36 C56 36, 58 34, 60 30" fill="none" stroke="currentColor" stroke-width="1.5" />
        <path d="M60 8 C65 8, 78 14, 82 22 C86 30, 80 36, 68 36 C64 36, 62 34, 60 30" fill="none" stroke="currentColor" stroke-width="1.5" />
        <path d="M52 36 C48 32, 44 26, 42 20" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
        <path d="M68 36 C72 32, 76 26, 78 20" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
        <circle cx="60" cy="12" r="2" fill="currentColor" />
        <path d="M58 10 C55 4, 50 2, 48 4" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.6" />
        <path d="M62 10 C65 4, 70 2, 72 4" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.6" />
        <text x="90" y="24" fill="currentColor" font-family="var(--font-display)" font-size="11" font-weight="700" letter-spacing="0.1em">MOTH</text>
      </svg>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-8">
      {nav.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-xs font-[family-name:var(--font-mono)] tracking-[0.1em] uppercase transition-colors hover:text-moth focus-moth',
            currentPath === link.href || currentPath.startsWith(link.href + '/')
              ? 'text-moth'
              : 'text-bone/50',
          ]}
        >{link.label}</a>
      ))}
      <a
        href="/play"
        class="text-xs font-[family-name:var(--font-mono)] tracking-[0.1em] uppercase px-5 py-2 bg-moth text-moss hover:bg-moth-dim transition-colors focus-moth font-medium"
      >Play</a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-toggle"
      class="md:hidden text-bone/60 hover:text-moth focus-moth p-2"
      aria-label="Toggle menu"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 5H18" /><path d="M2 10H18" /><path d="M2 15H18" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="hidden fixed inset-0 z-[60] bg-moss/98 backdrop-blur-lg flex-col items-center justify-center"
>
  <button
    id="mobile-close"
    class="absolute top-5 right-5 text-bone/60 hover:text-moth focus-moth p-2"
    aria-label="Close menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 6L18 18M18 6L6 18" />
    </svg>
  </button>
  <div class="flex flex-col items-center gap-8">
    {nav.map((link) => (
      <a
        href={link.href}
        class:list={[
          'font-[family-name:var(--font-display)] text-3xl tracking-wide transition-colors focus-moth',
          currentPath === link.href ? 'text-moth' : 'text-bone/60 hover:text-bone',
        ]}
      >{link.label}</a>
    ))}
    <a
      href="/play"
      class="inline-block px-8 py-3 bg-moth text-moss font-[family-name:var(--font-mono)] text-sm tracking-wider uppercase hover:bg-moth-dim transition-colors focus-moth"
    >Play the Demo</a>
  </div>
</div>
