---
const nav = [
  { label: 'World', href: '/world' },
  { label: 'Bestiary', href: '/bestiary' },
  { label: 'Play', href: '/play' },
  { label: 'Chronicle', href: '/chronicle' },
  { label: 'Summon', href: '/summon' },
];
const social = [
  { label: 'Twitter', href: 'https://twitter.com/mothtongue' },
  { label: 'Discord', href: 'https://discord.gg/mothtongue' },
  { label: 'Itch.io', href: 'https://mothtongue.itch.io' },
];
---
<footer class="border-t border-bone/5 bg-moss">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="focus-moth">
          <svg viewBox="0 0 120 40" class="w-20 h-7 text-bone" aria-label="MOTHTONGUE" role="img">
            <path d="M60 8 C55 8, 42 14, 38 22 C34 30, 40 36, 52 36 C56 36, 58 34, 60 30" fill="none" stroke="currentColor" stroke-width="1.5" />
            <path d="M60 8 C65 8, 78 14, 82 22 C86 30, 80 36, 68 36 C64 36, 62 34, 60 30" fill="none" stroke="currentColor" stroke-width="1.5" />
            <path d="M52 36 C48 32, 44 26, 42 20" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
            <path d="M68 36 C72 32, 76 26, 78 20" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
            <circle cx="60" cy="12" r="2" fill="currentColor" />
            <path d="M58 10 C55 4, 50 2, 48 4" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.6" />
            <path d="M62 10 C65 4, 70 2, 72 4" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.6" />
            <text x="90" y="24" fill="currentColor" font-family="var(--font-display)" font-size="11" font-weight="700" letter-spacing="0.1em">MOTH</text>
          </svg>
        </a>
        <p class="font-[family-name:var(--font-mono)] text-[10px] text-bone/30 mt-3 leading-relaxed">
          Speak to the things that glow.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="font-[family-name:var(--font-mono)] text-[10px] tracking-[0.2em] text-bone/40 uppercase mb-4">Explore</h4>
        <ul class="space-y-2">
          {nav.map((link) => (
            <li>
              <a href={link.href} class="font-[family-name:var(--font-mono)] text-[11px] text-bone/30 hover:text-moth transition-colors focus-moth">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-[family-name:var(--font-mono)] text-[10px] tracking-[0.2em] text-bone/40 uppercase mb-4">Connect</h4>
        <ul class="space-y-2">
          {social.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="font-[family-name:var(--font-mono)] text-[11px] text-bone/30 hover:text-moth transition-colors focus-moth">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-[family-name:var(--font-mono)] text-[10px] tracking-[0.2em] text-bone/40 uppercase mb-4">Field Dispatch</h4>
        <form class="flex" onsubmit="return false;">
          <input
            type="email"
            placeholder="your@email.com"
            required
            class="flex-1 px-3 py-2 bg-moss-light border border-bone/10 font-[family-name:var(--font-mono)] text-[10px] text-bone placeholder:text-bone/20 focus:border-moth transition-colors focus-moth"
            aria-label="Email for field dispatch"
          />
          <button
            type="submit"
            class="px-3 py-2 bg-moth text-moss font-[family-name:var(--font-mono)] text-[10px] font-medium hover:bg-moth-dim transition-colors focus-moth"
            aria-label="Subscribe"
          >Join</button>
        </form>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-bone/5">
      <p class="font-[family-name:var(--font-mono)] text-[9px] text-bone/15 leading-relaxed">
        MOTHTONGUE is an atmospheric narrative experience. Not affiliated with any real entomological institution. All specimens are fictional. The glow is not real. Or is it.
      </p>
      <p class="font-[family-name:var(--font-mono)] text-[9px] text-bone/10 mt-3">
        &copy; 2026 MOTHTONGUE. All rights reserved. The moths remember.
      </p>
    </div>
  </div>
</footer>
