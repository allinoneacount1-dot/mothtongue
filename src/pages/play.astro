---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/SectionLabel.astro';
---
<Layout title="Play" description="The Lantern Game — a playable demonstration of MOTHTONGUE.">
  <Nav slot="nav" />

  <main class="min-h-screen pt-28 pb-8 px-4 md:px-8">
    <div class="max-w-5xl mx-auto">
      <SectionLabel label="Interactive Demo" class="mb-4" />
      <h1 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold mb-4">
        The Lantern Game
      </h1>
      <p class="font-[family-name:var(--font-mono)] text-xs text-bone/40 mb-6 max-w-lg">
        Move your cursor to guide the lantern. The moths are drawn to its light. Watch them gather.
      </p>

      <div id="game-container" class="relative border border-bone/10 overflow-hidden bg-moss/50" style="height: 60vh; min-height: 400px;">
        <canvas id="play-canvas" class="w-full h-full cursor-none"></canvas>
        <div id="score" class="absolute top-4 right-4 font-[family-name:var(--font-mono)] text-[10px] text-bone/30 tracking-wider">
          MOTHS NEARBY: 0
        </div>
        <div id="instructions" class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <p class="font-[family-name:var(--font-mono)] text-xs text-bone/30 animate-pulse">
            Hover to begin
          </p>
        </div>
      </div>

      <p class="font-[family-name:var(--font-mono)] text-[9px] text-bone/20 mt-4 tracking-wider text-center">
        This is a demonstration of the MOTHTONGUE interaction language. The full experience is still in development.
      </p>
    </div>
  </main>

  <Footer slot="footer" />
</Layout>

<script>
  const canvas = document.getElementById('play-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('Canvas not found');

  const ctx = canvas.getContext('2d')!;
  const scoreEl = document.getElementById('score')!;
  const instructions = document.getElementById('instructions')!;
  const container = document.getElementById('game-container')!;

  let isPlaying = false;

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number; opacity: number;
    hue: number; pulse: number;
  }

  interface Lantern {
    x: number; y: number;
    targetX: number; targetY: number;
  }

  const lantern: Lantern = { x: 400, y: 300, targetX: 400, targetY: 300 };
  const mouse = { x: 400, y: 300 };
  let particles: Particle[] = [];

  function initParticles(w: number, h: number) {
    particles = [];
    for (let i = 0; i < 80; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.3) * 0.3,
        size: Math.random() * 3 + 1,
        opacity: Math.random() * 0.5 + 0.1,
        hue: Math.random() > 0.6 ? 80 : Math.random() > 0.3 ? 160 : 30,
        pulse: Math.random() * Math.PI * 2,
      });
    }
  }

  function resize() {
    canvas.width = canvas.offsetWidth * window.devicePixelRatio;
    canvas.height = canvas.offsetHeight * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    if (particles.length === 0) {
      initParticles(canvas.offsetWidth, canvas.offsetHeight);
    }
  }

  function onMouseMove(e: MouseEvent) {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  }

  function onTouchMove(e: TouchEvent) {
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    mouse.x = touch.clientX - rect.left;
    mouse.y = touch.clientY - rect.top;
  }

  function onMouseEnter() {
    if (!isPlaying) {
      isPlaying = true;
      instructions.style.display = 'none';
    }
  }

  resize();
  window.addEventListener('resize', resize);
  canvas.addEventListener('mousemove', onMouseMove);
  canvas.addEventListener('touchmove', onTouchMove, { passive: true });
  canvas.addEventListener('mouseenter', onMouseEnter);

  let count = 0;

  function animate() {
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    ctx.clearRect(0, 0, w, h);

    // Lantern follows mouse
    lantern.targetX = mouse.x;
    lantern.targetY = mouse.y;
    lantern.x += (lantern.targetX - lantern.x) * 0.08;
    lantern.y += (lantern.targetY - lantern.y) * 0.08;

    // Lantern glow
    const gradient = ctx.createRadialGradient(lantern.x, lantern.y, 0, lantern.x, lantern.y, 120);
    gradient.addColorStop(0, 'rgba(200, 255, 120, 0.15)');
    gradient.addColorStop(0.5, 'rgba(200, 255, 120, 0.05)');
    gradient.addColorStop(1, 'rgba(200, 255, 120, 0)');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, w, h);

    // Lantern body
    ctx.fillStyle = 'rgba(200, 255, 120, 0.9)';
    ctx.beginPath();
    ctx.arc(lantern.x, lantern.y, 6, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = 'rgba(200, 255, 120, 0.3)';
    ctx.beginPath();
    ctx.arc(lantern.x, lantern.y, 12, 0, Math.PI * 2);
    ctx.fill();

    count = 0;
    for (const p of particles) {
      p.pulse += 0.02;
      const pulseOpacity = p.opacity * (0.7 + Math.sin(p.pulse) * 0.3);

      const dx = lantern.x - p.x;
      const dy = lantern.y - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < 150 && dist > 20) {
        p.vx += (dx / dist) * 0.02;
        p.vy += (dy / dist) * 0.02;
      }
      if (dist < 25) {
        p.vx -= (dx / dist) * 0.1;
        p.vy -= (dy / dist) * 0.1;
      }

      p.vx *= 0.98;
      p.vy *= 0.98;
      p.x += p.vx;
      p.y += p.vy;

      if (p.x < 0) p.x = w;
      if (p.x > w) p.x = 0;
      if (p.y < 0) p.y = h;
      if (p.y > h) p.y = 0;

      if (dist < 100) count++;

      const color = p.hue === 80
        ? `rgba(200, 255, 120, ${pulseOpacity})`
        : p.hue === 160
        ? `rgba(120, 255, 200, ${pulseOpacity})`
        : `rgba(255, 160, 80, ${pulseOpacity})`;

      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = color.replace(/[\d.]+\)$/, `${pulseOpacity * 0.3})`);
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
      ctx.fill();
    }

    scoreEl.textContent = `MOTHS NEARBY: ${count}`;
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
