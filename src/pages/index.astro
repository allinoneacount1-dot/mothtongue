---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MothParticles from '../components/MothParticles.astro';
import WoodcutDraw from '../components/WoodcutDraw.astro';
import RevealText from '../components/RevealText.astro';
import MagneticButton from '../components/MagneticButton.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { creatures } from '../data/bestiary';

const worldHighlights = [
  { title: 'The Archive', desc: 'A museum of night things, catalogued by lantern light.', href: '/world' },
  { title: 'The Tale', desc: 'A dark folk story told through woodcut and glow.', href: '/world#tale' },
  { title: 'The Translator', desc: 'You. The one who speaks the language of light.', href: '/world#translator' },
];
---
<Layout>
  <Nav slot="nav" />

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <MothParticles />

    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-8 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center pt-24 pb-16">
      <div>
        <SectionLabel label="Field Entry 001, Nocturnal" class="mb-6" />

        <RevealText>
          <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.05] tracking-tight mb-8">
            Speak to the things that glow.
          </h1>
        </RevealText>

        <p class="font-[family-name:var(--font-mono)] text-xs md:text-sm text-bone/50 max-w-lg mb-10 leading-relaxed reveal reveal-delay-2">
          A nocturnal museum that came alive. You are the translator.
        </p>

        <div class="flex flex-wrap gap-4 reveal reveal-delay-3">
          <MagneticButton href="/world">Enter the Glow</MagneticButton>
          <MagneticButton href="/play" variant="secondary">Play the Demo</MagneticButton>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end reveal">
        <div class="w-64 h-64 md:w-80 md:h-80 lg:w-96 lg:h-96 text-moth/40">
          <WoodcutDraw />
        </div>
      </div>
    </div>
  </section>

  <!-- Lore teaser -->
  <section class="section-spacing px-4 md:px-8">
    <div class="max-w-4xl mx-auto">
      <RevealText>
        <p class="font-[family-name:var(--font-display)] text-2xl md:text-3xl lg:text-4xl leading-snug text-bone/90 drop-cap">
          Somewhere in the deep forest, an abandoned museum breathes in the dark. Its display cases hum. Its specimen labels shift. The moths pinned behind glass have begun to glow again, and they are speaking to anyone who will listen.
        </p>
      </RevealText>
      <div class="mt-8">
        <a href="/world" class="font-[family-name:var(--font-mono)] text-xs text-moth hover:text-moth-dim transition-colors focus-moth tracking-wider uppercase">
          Read the full entry &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- World grid -->
  <section class="section-spacing px-4 md:px-8 border-t border-bone/5">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {worldHighlights.map((item, i) => (
          <a
            href={item.href}
            class:list={['group block p-8 border border-bone/10 hover:border-moth/30 transition-all duration-500', `reveal reveal-delay-${i + 1}`]}
          >
            <span class="font-[family-name:var(--font-mono)] text-[10px] text-bone/20 tracking-widest">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold mt-3 mb-3 text-bone group-hover:text-moth transition-colors">
              {item.title}
            </h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-bone/40 leading-relaxed">
              {item.desc}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Character strip -->
  <section class="section-spacing px-4 md:px-8 border-t border-bone/5">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {creatures.map((c) => (
          <a
            href={`/bestiary/${c.slug}`}
            class="group block text-center p-4 hover:bg-bone/5 transition-colors reveal"
          >
            <div
              class="w-16 h-16 mx-auto mb-3 rounded-full flex items-center justify-center"
              style={`background-color: ${c.glowColor}15; box-shadow: 0 0 30px ${c.glowColor}20`}
            >
              <span class="font-[family-name:var(--font-display)] text-lg" style={`color: ${c.glowColor}`}>
                {c.name.charAt(0)}
              </span>
            </div>
            <p class="font-[family-name:var(--font-mono)] text-[10px] text-bone/50 group-hover:text-bone transition-colors">
              {c.name}
            </p>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/bestiary" class="font-[family-name:var(--font-mono)] text-xs text-moth hover:text-moth-dim transition-colors focus-moth tracking-wider uppercase">
          View Full Bestiary &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Demo CTA -->
  <section class="section-spacing px-4 md:px-8 border-t border-bone/5">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Guide the light. Read the glow.
      </h2>
      <p class="font-[family-name:var(--font-mono)] text-xs text-bone/40 mb-8 max-w-lg mx-auto">
        A playable demonstration of the MOTHTONGUE experience. Navigate a lantern through the dark forest. Let the moths teach you their language.
      </p>
      <MagneticButton href="/play">
        Play the Demo
      </MagneticButton>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
