---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { chroniclePosts as posts } from '../../data/chronicle';
---
<Layout title="Chronicle" description="Field notes, dark folk tales, and transmissions from the nocturnal archive.">
  <Nav slot="nav" />

  <main class="min-h-screen pt-28 pb-20 px-4 md:px-8">
    <div class="max-w-4xl mx-auto">
      <SectionLabel label="Field Notes" class="mb-4" />
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-6xl font-bold mb-8">
        The Chronicle
      </h1>

      <p class="font-[family-name:var(--font-mono)] text-xs text-bone/40 mb-16 max-w-2xl leading-relaxed">
        Dispatches from the nocturnal archive. Field notes, dark folk tales, and transmissions from the translators who came before you.
      </p>

      <div class="space-y-8">
        {posts.map((post, i) => (
          <div class:list={['reveal', `reveal-delay-${Math.min(i + 1, 5)}`]}>
            <a
              href={`/chronicle/${post.slug}`}
              class="group block border border-bone/10 p-8 md:p-12 hover:border-bone/20 transition-all duration-500"
            >
              <div class="flex items-center gap-3 mb-4">
                <span class="font-[family-name:var(--font-mono)] text-[9px] text-bone/25 tracking-[0.2em] uppercase">
                  {post.tags[0]}
                </span>
                <span class="text-bone/10">·</span>
                <span class="font-[family-name:var(--font-mono)] text-[9px] text-bone/25">
                  {post.date}
                </span>
              </div>
              <h2 class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold mb-3 text-bone group-hover:text-moth transition-colors">
                {post.title}
              </h2>
              <p class="font-[family-name:var(--font-mono)] text-[11px] text-bone/40 leading-relaxed line-clamp-2">
                {post.excerpt}
              </p>
              <div class="mt-4">
                <span class="font-[family-name:var(--font-mono)] text-[9px] text-bone/20 tracking-wider group-hover:text-moth/50 transition-colors">
                  Read Entry &rarr;
                </span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer slot="footer" />
</Layout>
